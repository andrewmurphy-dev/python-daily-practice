#compare two lists side by side ! 
def compare_lists(list1, list2):
    a = []
    b = [] 
    for i in range(len(list1)):
        for j in range(len(list2)):
            if len(list1[i]) == len(list2[j]):
                a.append(list1[i])
                b.append(list2[j])
    return a, b
