updated flow


# 1. Go to the folder where you keep projects
cd /Users/andrewmurphy/Python-auth-project

# 2. Clone the repo
git clone REPO_URL

# 3. Go into the project
cd python-cli-auth-system

# 4. Create the project virtual environment
python3 -m venv .venv

# 5. Install the project packages into the .venv
.venv/bin/python -m pip install -r requirements.txt

# 6. Check the project Python
.venv/bin/python --version

# 7. Check requests is installed in the project Python
.venv/bin/python -c "import requests; print(requests.__version__)"

# 8. Check your file has no syntax errors
.venv/bin/python -m py_compile app/core/auth.py

# 9. Start the FastAPI server
.venv/bin/python -m uvicorn app.main_api:app --reload

# 10. In a second terminal, run the CLI
cd /Users/andrewmurphy/Python-auth-project/python-cli-auth-system
.venv/bin/python app/cli/cli.main.py