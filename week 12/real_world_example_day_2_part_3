#bank withdrawl


def get_withdraw_amount(balance):
    
    
    while True:
        withdraw_text = input("enter withdrawl amount: ").strip()
    
        if withdraw_text == "":
           print("cannot be empty")
           continue
        
        
        try:
            withdraw = int(withdraw_text)  
        except ValueError:
           print("please enter the correct input!")
           continue
        
        
        if withdraw <= 0:
           print("amount must be greater than 0")
           continue 
           
        elif withdraw > balance:
            print("insufficient balance")
        
        
        return withdraw
        

    
        
