def test_get_users_response_format():
response = client.get("/users")
users = response.json(). ==> converting the json to python data format 

assert response.status_code == 200

for user in users:
assert set(user.keys()) == {"id", "name", "password", "created_at"}
assert isinstance(user["id"], int) --> checking if it has the correct type 
assert isinstance(user["name], str)
assert isinstance(user["password"], str)
assert isinstance(user["created_at"], str)




